{
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "prepare": "node -e \"try { require('husky').install() } catch (e) {if (e.code !== 'MODULE_NOT_FOUND') throw e}\"",
        "prettier": "prettier --end-of-line=lf app/**/* routes/**/* --write",
        "tunnel": "npx localtunnel --port 8000 --subdomain tame-donuts-wait",
        "tunnel:ssh": "ssh -o StrictHostKeyChecking=no -R 80:127.0.0.1:8000 nokey@localhost.run",
        "tunnel:ngrok": "npx ngrok http 8000 --domain=foam-proximity-unraveled.ngrok-free.dev",
        "dev:tunnel": "node scripts/check-docker.js && concurrently \"php artisan serve\" \"npm run tunnel:ngrok\"",
        "dev:ssh": "node scripts/check-docker.js && concurrently \"php artisan serve\" \"npm run tunnel:ssh\""
    },
    "devDependencies": {
        "@prettier/plugin-php": "^0.18.9",
        "axios": "^0.27",
        "concurrently": "^10.0.3",
        "husky": "^8.0.1",
        "laravel-vite-plugin": "^0.5.0",
        "lodash": "^4.17.19",
        "postcss": "^8.1.14",
        "prettier": "^2.7.1",
        "vite": "^3.0.0"
    }
}
