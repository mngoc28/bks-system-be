{
  "mcpServers": {
    "aws-knowledge": {
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp@latest", "--headed"]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "stitch": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "stitch-mcp-server"],
      "envFile": "${workspaceFolder}/.cursor/stitch.env"
    }
  }
}
